{
  "version": 2,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "frontend/build" } },
    { "src": "api/asgi.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/asgi.py" },
    { "src": "/static/(.*)", "dest": "/frontend/build/static/$1" },
    { "src": "^/(favicon.ico|manifest.json)$", "dest": "/frontend/build/$1" },
    { "src": "/(.*)", "dest": "/frontend/build/index.html" }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "BonCafe.settings",
    "PYTHONUNBUFFERED": "1"
  }
}

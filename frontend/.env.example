# Django Backend API Configuration
REACT_APP_API_URL=http://localhost:8000/api

# Django Media URL (for images and static files)
REACT_APP_MEDIA_URL=http://localhost:8000

# Environment
REACT_APP_ENV=development

# API Configuration
REACT_APP_API_TIMEOUT=10000

# Contact Information
REACT_APP_SUPPORT_EMAIL=support@boncafe.uz

# Optional: Analytics (remove if not needed)
REACT_APP_GA_TRACKING_ID=your_ga_tracking_id_here

# Application Settings
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_ENABLE_PWA=true

# Performance Settings
REACT_APP_ENABLE_PERFORMANCE_MONITORING=false